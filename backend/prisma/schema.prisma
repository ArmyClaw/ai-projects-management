generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CapabilityStatus {
  DRAFT
  ACTIVE
  DEPRECATED
  ARCHIVED
}

enum HealthStatus {
  UNKNOWN
  HEALTHY
  UNHEALTHY
  DEGRADED
}

enum ModelTier {
  PREMIUM
  BALANCED
  ECONOMY
}

enum QuestStatus {
  OPEN
  ADOPTED
  CLOSED
}

enum QuestApplicationStatus {
  APPLIED
  ADOPTED
  REJECTED
}

model Model {
  id          String           @id
  name        String
  provider    String
  modelId     String
  tier        ModelTier
  status      CapabilityStatus @default(DRAFT)
  healthStatus HealthStatus    @default(UNKNOWN)
  createdBy   String           @default("system")
  updatedBy   String           @default("system")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  agents      Agent[]
  assignments ProjectRoleAgent[]
  primaryForRoles AgentRoleProfile[] @relation("PrimaryRoleModel")
  assistantForRoles AgentRoleProfile[] @relation("AssistantRoleModel")
}

model Skill {
  id         String           @id
  name       String
  version    String
  status     CapabilityStatus @default(DRAFT)
  tags       String[]
  definition Json
  createdBy  String           @default("system")
  updatedBy  String           @default("system")
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([name, version])
  @@index([status])
}

model Mcp {
  id         String           @id
  name       String
  transport  String
  endpoint   String
  status     CapabilityStatus @default(DRAFT)
  tags       String[]
  definition Json
  createdBy  String           @default("system")
  updatedBy  String           @default("system")
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([name, endpoint])
  @@index([status])
}

model Agent {
  id             String  @id
  name           String
  roleId         String
  workload       Int
  defaultModelId String?
  skillIds       String[] @default([])
  workflow       Json?
  createdBy      String   @default("system")
  updatedBy      String   @default("system")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  defaultModel   Model?   @relation(fields: [defaultModelId], references: [id])
  assignments    ProjectRoleAgent[]
}

model AgentRoleProfile {
  roleId            String   @id
  skillIds          String[] @default([])
  workflow          Json?
  workloadMarkdown  String   @default("")
  primaryModelId    String
  assistantModelId  String
  createdBy         String   @default("system")
  updatedBy         String   @default("system")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  primaryModel      Model @relation("PrimaryRoleModel", fields: [primaryModelId], references: [id], onDelete: Restrict)
  assistantModel    Model @relation("AssistantRoleModel", fields: [assistantModelId], references: [id], onDelete: Restrict)

  @@index([primaryModelId])
  @@index([assistantModelId])
}

model Project {
  id          String   @id
  name        String
  createdBy   String   @default("system")
  updatedBy   String   @default("system")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments ProjectRoleAgent[]
  questApplications TaskQuestApplication[]
}

model ProjectRoleAgent {
  id             String         @id @default(uuid())
  projectId      String
  roleId         String
  agentId        String
  modelId        String
  priority       Int
  createdBy      String         @default("system")
  updatedBy      String         @default("system")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Restrict)
  model   Model   @relation(fields: [modelId], references: [id], onDelete: Restrict)

  @@unique([projectId, roleId, agentId])
  @@index([projectId, roleId])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  beforeData Json?
  afterData  Json?
  createdAt  DateTime @default(now())
}

model TaskQuest {
  id                   String        @id @default(uuid())
  title                String
  detail               String
  reward               String
  status               QuestStatus   @default(OPEN)
  publisherId          String
  adoptedApplicationId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  applications         TaskQuestApplication[]

  @@index([publisherId, status])
}

model TaskQuestApplication {
  id          String                 @id @default(uuid())
  taskId      String
  projectId   String
  applicantId String
  message     String                 @default("")
  status      QuestApplicationStatus @default(APPLIED)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  task        TaskQuest              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project     Project                @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@unique([taskId, projectId])
  @@index([applicantId])
}

model User {
  id           String        @id @default(uuid())
  handle       String        @unique
  displayName  String
  avatar       String        @default("")
  codingCliTools String[]    @default([])
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  sessions     UserSession[]
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
